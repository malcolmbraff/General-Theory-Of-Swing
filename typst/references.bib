@article{nollclampitt2018kaleidoscope,
	title = {Kaleidoscope substitutions and pairwise well-formed modes: major-minor duality transformationally revisited},
	volume = {12},
	issn = {1745-9737},
	url = {https://doi.org/10.1080/17459737.2018.1545056},
	doi = {10.1080/17459737.2018.1545056},
	shorttitle = {Kaleidoscope substitutions and pairwise well-formed modes},
	abstract = {Pairwise well-formed modes are investigated as substitutions on words over a three-letter alphabet. Motivating examples are the major and minor modes, here described in terms of the substitutions a↦ac,b↦ba,c↦cab and a↦ab,b↦ca,c↦bac. Pairwise well-formedness is investigated through the inspection of the two-letter-mergings of a substiution, namely concatenations with letter insertions from the right and letter projections from the left. The appropriate generalizations of the two mentioned examples are the plain and twisted kaleidoscope substitutions. Four of their mergings turn out to be Sturmian morphisms with interesting interdependencies. The diatonic mergings are musically related to the medieval modes, which are fifth-generated. The syntonic mergings are third-generated and provide a common neutral anchor for the major and minor modes. The paper thus provides a new proposal in order to integrate the diatonic side of harmonic tonality with its triadic aspects, which we characterize as its syntonic side.},
	pages = {171--211},
	number = {3},
	journaltitle = {Journal of Mathematics and Music},
	publisher = {Taylor \& Francis},
	author = {Noll, Thomas and Clampitt, David},
	urldate = {2026-04-20},
	date = {2018-09-02},
	note = {\_eprint: https://doi.org/10.1080/17459737.2018.1545056},
}

